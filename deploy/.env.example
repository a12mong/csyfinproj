# คัดลอกเป็น .env ไว้ที่ /opt/csyfinproj บน droplet แล้วกรอกค่าให้ครบ
#   cp .env.example .env && nano .env
# ห้าม commit ไฟล์ .env ลง git

# ===== Docker images (GHCR) =====
# ชื่อ user/org ของ GitHub ที่เป็นเจ้าของ repo (ตัวพิมพ์เล็ก)
GHCR_OWNER=your-github-username
# IMAGE_TAG ถูกเขียนทับโดย GitHub Actions ทุกครั้งที่ deploy — ไม่ต้องแก้เอง
IMAGE_TAG=latest

# ===== Instance identity (สำหรับรัน live + dev บนเครื่องเดียวกัน) =====
# เครื่องหนึ่งมี Caddy ได้ตัวเดียว: instance ที่ตั้ง COMPOSE_PROFILES=edge
# คือตัวที่รัน Caddy (ครองพอร์ต 80/443) และ serve ทุก instance ผ่าน
# docker network กลางชื่อ "edge" (สร้างครั้งเดียว: docker network create edge)
#
#            live (/opt/csyfinproj)   dev (/opt/csyfinproj-dev)
#   COMPOSE_PROJECT_NAME  csyfinproj              csyfinproj-dev
#   EDGE_ALIAS            live                    dev
#   COMPOSE_PROFILES      edge                    (เว้นว่าง/ไม่ต้องใส่)
#   DB_HOST_PORT          3306                    3307
#   APP_ENV               live                    dev  (dev = โชว์ badge "DEV" บน nav)
COMPOSE_PROJECT_NAME=csyfinproj
EDGE_ALIAS=live
COMPOSE_PROFILES=edge
DB_HOST_PORT=3306
APP_ENV=live
# เฉพาะ instance ที่รัน Caddy: domain ของ dev instance บนเครื่องเดียวกัน
# (ไม่มี dev ให้คงคอมเมนต์ไว้)
#DEV_SITE_ADDRESS=dev.example.com

# ===== Domain / URLs =====
# มี domain:  SITE_ADDRESS=app.example.com  (Caddy จะออก HTTPS ให้อัตโนมัติ)
# ยังไม่มี:   SITE_ADDRESS=:80  (ใช้ผ่าน http://<droplet-ip> ชั่วคราว
#             *** แต่ login จะไม่ทำงานใน production mode เพราะ cookie ตั้ง
#             secure + SameSite=None ซึ่งต้องใช้ HTTPS — แนะนำให้มี domain ***)
SITE_ADDRESS=app.example.com
# ต้องตรงกับ origin ที่ผู้ใช้เปิดเว็บ (ใช้ตรวจ CORS ของ API)
CORS_ORIGIN=https://app.example.com
# origin สาธารณะของ API (ใช้สร้าง webhook URL ของ LINE ฯลฯ)
PUBLIC_API_URL=https://app.example.com

# ===== MySQL (container "db") =====
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
MYSQL_DATABASE=csyfinproj
MYSQL_USER=csyfin
MYSQL_PASSWORD=change-me-strong-password
# ถ้าจะใช้ DigitalOcean Managed MySQL แทน container ให้ uncomment บรรทัดนี้
# แล้วชี้ไปที่ managed DB (ตัวแปร MYSQL_* ด้านบนจะไม่ถูกใช้โดย api)
#DATABASE_URL=mysql://user:pass@your-managed-db-host:25060/csyfinproj?ssl-mode=REQUIRED

# ===== Auth =====
# สร้างด้วย: openssl rand -base64 48
JWT_SECRET=change-me-random-secret

# ===== LINE Messaging API =====
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ID=

# ===== SMS Gateway =====
SMS_API_KEY=

# ===== Email SMTP =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== อื่น ๆ =====
# อัตรา VAT เป็นเปอร์เซ็นต์ (ค่า default ในโค้ดคือ 7)
#VAT_RATE=7

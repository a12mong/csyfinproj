generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
  viewer
}

enum MotorcycleStatus {
  in_stock
  reserved
  sold
}

enum PaymentMethod {
  cash
  installment
}

enum SaleStatus {
  active
  completed
  defaulted
  cancelled
}

enum InstallmentStatus {
  pending
  paid
  overdue
  partially_paid
}

enum NotificationChannel {
  line
  sms
  email
}

enum NotificationStatus {
  sent
  failed
  pending
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         UserRole @default(staff)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sales             Sale[]
  verifiedPayments  Payment[] @relation("VerifiedBy")

  @@map("users")
}

model Customer {
  id           String   @id @default(uuid()) @db.VarChar(36)
  name         String   @db.VarChar(255)
  phone        String   @db.VarChar(20)
  email        String?  @db.VarChar(255)
  lineId       String?  @map("line_id") @db.VarChar(100)
  address      String?  @db.Text
  idCardNumber String   @unique @map("id_card_number") @db.VarChar(13)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sales             Sale[]
  notificationLogs  NotificationLog[]

  @@map("customers")
}

model Motorcycle {
  id            String           @id @default(uuid()) @db.VarChar(36)
  brand         String           @default("Yamaha") @db.VarChar(100)
  model         String           @db.VarChar(255)
  year          Int
  chassisNumber String           @unique @map("chassis_number") @db.VarChar(100)
  engineNumber  String           @unique @map("engine_number") @db.VarChar(100)
  color         String           @db.VarChar(50)
  costPrice     Decimal          @map("cost_price") @db.Decimal(12, 2)
  sellingPrice  Decimal          @map("selling_price") @db.Decimal(12, 2)
  status        MotorcycleStatus @default(in_stock)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  sales Sale[]

  @@index([status])
  @@map("motorcycles")
}

model Sale {
  id              String        @id @default(uuid()) @db.VarChar(36)
  customerId      String        @map("customer_id") @db.VarChar(36)
  motorcycleId    String        @map("motorcycle_id") @db.VarChar(36)
  saleDate        DateTime      @map("sale_date") @db.Date
  totalPrice      Decimal       @map("total_price") @db.Decimal(12, 2)
  downPayment     Decimal       @map("down_payment") @db.Decimal(12, 2)
  financeAmount   Decimal       @map("finance_amount") @db.Decimal(12, 2)
  numInstallments Int           @map("num_installments")
  interestRate    Decimal       @map("interest_rate") @db.Decimal(5, 2)
  paymentMethod   PaymentMethod @map("payment_method")
  status          SaleStatus    @default(active)
  notes           String?       @db.Text
  soldByUserId    String        @map("sold_by_user_id") @db.VarChar(36)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer     Customer      @relation(fields: [customerId], references: [id])
  motorcycle   Motorcycle    @relation(fields: [motorcycleId], references: [id])
  soldBy       User          @relation(fields: [soldByUserId], references: [id])
  installments Installment[]
  saleAddons   SaleAddon[]

  @@index([customerId])
  @@map("sales")
}

model Installment {
  id                String            @id @default(uuid()) @db.VarChar(36)
  saleId            String            @map("sale_id") @db.VarChar(36)
  installmentNumber Int               @map("installment_number")
  dueDate           DateTime          @map("due_date") @db.Date
  amountDue         Decimal           @map("amount_due") @db.Decimal(12, 2)
  amountPaid        Decimal           @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status            InstallmentStatus @default(pending)
  paidAt            DateTime?         @map("paid_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  sale             Sale              @relation(fields: [saleId], references: [id])
  payments         Payment[]
  notificationLogs NotificationLog[]

  @@index([saleId, dueDate])
  @@index([status])
  @@map("installments")
}

model Payment {
  id               String   @id @default(uuid()) @db.VarChar(36)
  installmentId    String   @map("installment_id") @db.VarChar(36)
  amount           Decimal  @db.Decimal(12, 2)
  paymentDate      DateTime @map("payment_date") @db.Date
  slipImageUrl     String?  @map("slip_image_url") @db.VarChar(500)
  verified         Boolean  @default(false)
  verifiedByUserId String?  @map("verified_by_user_id") @db.VarChar(36)
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at")

  installment Installment @relation(fields: [installmentId], references: [id])
  verifiedBy  User?       @relation("VerifiedBy", fields: [verifiedByUserId], references: [id])

  @@index([installmentId])
  @@map("payments")
}

model NotificationLog {
  id            String             @id @default(uuid()) @db.VarChar(36)
  customerId    String             @map("customer_id") @db.VarChar(36)
  installmentId String?            @map("installment_id") @db.VarChar(36)
  channel       NotificationChannel
  message       String             @db.Text
  status        NotificationStatus @default(pending)
  sentAt        DateTime?          @map("sent_at")
  createdAt     DateTime           @default(now()) @map("created_at")

  customer    Customer     @relation(fields: [customerId], references: [id])
  installment Installment? @relation(fields: [installmentId], references: [id])

  @@index([customerId, channel])
  @@map("notification_logs")
}

model Addon {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")

  saleAddons SaleAddon[]

  @@map("addons")
}

model SaleAddon {
  id          String   @id @default(uuid()) @db.VarChar(36)
  saleId      String   @map("sale_id") @db.VarChar(36)
  addonId     String   @map("addon_id") @db.VarChar(36)
  priceAtSale Decimal  @map("price_at_sale") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  sale  Sale  @relation(fields: [saleId], references: [id])
  addon Addon @relation(fields: [addonId], references: [id])

  @@map("sale_addons")
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  staff
  viewer
}

enum PermissionPage {
  dashboard
  inventory
  receiving
  sales
  customers
  finance
  payments
  settings
}

enum MotorcycleStatus {
  in_stock
  reserved
  sold
}

enum PaymentMethod {
  cash
  installment
  finance_company
}

enum CustomerType {
  personal
  individual
  finance
}

enum PaymentChannel {
  cash
  bank_transfer
  line
}

enum DeliveryNoteStatus {
  pending
  verified
  cancelled
}

enum DeliveryItemType {
  motorcycle
  part
  accessory
}

enum SaleStatus {
  active
  completed
  defaulted
  cancelled
}

enum InstallmentStatus {
  pending
  paid
  overdue
  partially_paid
}

enum NotificationChannel {
  line
  sms
  email
}

enum ContractStatus {
  active
  completed
  defaulted
  cancelled
}

enum ContractPartyRole {
  owner
  buyer
  seller
}

enum NotificationStatus {
  sent
  failed
  pending
}

model User {
  id           String   @id @default(uuid()) @db.VarChar(36)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @db.VarChar(255)
  role         UserRole @default(staff)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  active        Boolean  @default(true)

  sales             Sale[]
  verifiedPayments  Payment[] @relation("VerifiedBy")
  deliveryNotes     DeliveryNote[]
  permissions       UserPermission[]
  createdContracts  Contract[] @relation("CreatedContracts")

  @@map("users")
}

model UserPermission {
  id        String         @id @default(uuid()) @db.VarChar(36)
  userId    String         @map("user_id") @db.VarChar(36)
  page      PermissionPage
  canView   Boolean        @default(false) @map("can_view")
  canCreate Boolean        @default(false) @map("can_create")
  canEdit   Boolean        @default(false) @map("can_edit")
  canDelete Boolean        @default(false) @map("can_delete")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, page])
  @@index([userId])
  @@map("user_permissions")
}

model Customer {
  id           String       @id @default(uuid()) @db.VarChar(36)
  name         String       @db.VarChar(255)
  phone        String       @db.VarChar(20)
  email        String?      @db.VarChar(255)
  lineId       String?      @map("line_id") @db.VarChar(100)
  address      String?      @db.Text
  idCardNumber String       @unique @map("id_card_number") @db.VarChar(13)
  type         CustomerType @default(personal)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  sales             Sale[]
  invoiceSales      Sale[] @relation("InvoiceCustomer")
  buyerSales        Sale[] @relation("BuyerCustomer")
  notificationLogs  NotificationLog[]
  contracts         Contract[]

  @@map("customers")
}

model Motorcycle {
  id            String           @id @default(uuid()) @db.VarChar(36)
  brand         String           @default("Yamaha") @db.VarChar(100)
  model         String           @db.VarChar(255)
  year          Int
  chassisNumber String           @unique @map("chassis_number") @db.VarChar(100)
  engineNumber  String           @unique @map("engine_number") @db.VarChar(100)
  color         String           @db.VarChar(50)
  costPrice     Decimal          @map("cost_price") @db.Decimal(12, 2)
  sellingPrice  Decimal          @map("selling_price") @db.Decimal(12, 2)
  status        MotorcycleStatus @default(in_stock)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  deliveryNoteItemId String?  @map("delivery_note_item_id") @db.VarChar(36)

  sales              Sale[]
  deliveryNoteItem   DeliveryNoteItem? @relation(fields: [deliveryNoteItemId], references: [id])

  @@index([status])
  @@map("motorcycles")
}

model Sale {
  id              String        @id @default(uuid()) @db.VarChar(36)
  customerId      String        @map("customer_id") @db.VarChar(36)
  invoiceCustomerId String?      @map("invoice_customer_id") @db.VarChar(36)
  buyerCustomerId String?        @map("buyer_customer_id") @db.VarChar(36)
  motorcycleId    String        @map("motorcycle_id") @db.VarChar(36)
  saleDate        DateTime      @map("sale_date") @db.Date
  totalPrice      Decimal       @map("total_price") @db.Decimal(12, 2)
  downPayment     Decimal       @map("down_payment") @db.Decimal(12, 2)
  financeAmount   Decimal       @map("finance_amount") @db.Decimal(12, 2)
  numInstallments Int           @map("num_installments")
  interestRate    Decimal       @map("interest_rate") @db.Decimal(5, 2)
  paymentMethod          PaymentMethod @map("payment_method")
  financeCompanyName     String?       @map("finance_company_name") @db.VarChar(255)
  financeReferenceNumber String?       @map("finance_reference_number") @db.VarChar(100)
  financialInstitutionId String?       @map("financial_institution_id") @db.VarChar(36)
  status                 SaleStatus    @default(active)
  notes                  String?       @db.Text
  soldByUserId           String        @map("sold_by_user_id") @db.VarChar(36)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  customer              Customer               @relation(fields: [customerId], references: [id])
  invoiceCustomer       Customer?              @relation("InvoiceCustomer", fields: [invoiceCustomerId], references: [id])
  buyerCustomer         Customer?              @relation("BuyerCustomer", fields: [buyerCustomerId], references: [id])
  motorcycle            Motorcycle             @relation(fields: [motorcycleId], references: [id])
  soldBy                User                   @relation(fields: [soldByUserId], references: [id])
  financialInstitution  FinancialInstitution?  @relation(fields: [financialInstitutionId], references: [id])
  installments          Installment[]
  saleAddons            SaleAddon[]
  contractSales         ContractSale[]

  @@index([customerId])
  @@index([invoiceCustomerId])
  @@index([buyerCustomerId])
  @@index([financialInstitutionId])
  @@map("sales")
}

model Installment {
  id                String            @id @default(uuid()) @db.VarChar(36)
  saleId            String?           @map("sale_id") @db.VarChar(36)
  contractId        String?           @map("contract_id") @db.VarChar(36)
  installmentNumber Int               @map("installment_number")
  dueDate           DateTime          @map("due_date") @db.Date
  amountDue         Decimal           @map("amount_due") @db.Decimal(12, 2)
  principalPortion  Decimal?          @map("principal_portion") @db.Decimal(12, 2)
  interestPortion   Decimal?          @map("interest_portion") @db.Decimal(12, 2)
  remainingBalance  Decimal?          @map("remaining_balance") @db.Decimal(12, 2)
  amountPaid        Decimal           @default(0) @map("amount_paid") @db.Decimal(12, 2)
  status            InstallmentStatus @default(pending)
  paidAt            DateTime?         @map("paid_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  sale             Sale?             @relation(fields: [saleId], references: [id])
  contract         Contract?         @relation(fields: [contractId], references: [id])
  payments         Payment[]
  notificationLogs NotificationLog[]

  @@index([saleId, dueDate])
  @@index([contractId])
  @@index([status])
  @@map("installments")
}

model Payment {
  id               String         @id @default(uuid()) @db.VarChar(36)
  installmentId    String?        @map("installment_id") @db.VarChar(36)
  contractId       String?        @map("contract_id") @db.VarChar(36)
  amount           Decimal        @db.Decimal(12, 2)
  paymentDate      DateTime       @map("payment_date") @db.Date
  paymentChannel   PaymentChannel @default(cash) @map("payment_channel")
  slipImageUrl     String?        @map("slip_image_url") @db.VarChar(500)
  verified         Boolean        @default(false)
  verifiedByUserId String?        @map("verified_by_user_id") @db.VarChar(36)
  lineMessageId    String?        @map("line_message_id") @db.VarChar(255)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now()) @map("created_at")

  installment Installment? @relation(fields: [installmentId], references: [id])
  contract    Contract?    @relation(fields: [contractId], references: [id])
  verifiedBy  User?        @relation("VerifiedBy", fields: [verifiedByUserId], references: [id])

  @@index([installmentId])
  @@index([contractId])
  @@map("payments")
}

model NotificationLog {
  id            String             @id @default(uuid()) @db.VarChar(36)
  customerId    String             @map("customer_id") @db.VarChar(36)
  installmentId String?            @map("installment_id") @db.VarChar(36)
  channel       NotificationChannel
  message       String             @db.Text
  status        NotificationStatus @default(pending)
  sentAt        DateTime?          @map("sent_at")
  createdAt     DateTime           @default(now()) @map("created_at")

  customer    Customer     @relation(fields: [customerId], references: [id])
  installment Installment? @relation(fields: [installmentId], references: [id])

  @@index([customerId, channel])
  @@map("notification_logs")
}

model Addon {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String    @db.VarChar(255)
  description String?   @db.Text
  price       Decimal   @db.Decimal(12, 2)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")

  saleAddons SaleAddon[]

  @@map("addons")
}

model SaleAddon {
  id          String   @id @default(uuid()) @db.VarChar(36)
  saleId      String   @map("sale_id") @db.VarChar(36)
  addonId     String   @map("addon_id") @db.VarChar(36)
  priceAtSale Decimal  @map("price_at_sale") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  sale  Sale  @relation(fields: [saleId], references: [id])
  addon Addon @relation(fields: [addonId], references: [id])

  @@map("sale_addons")
}

model DeliveryNote {
  id               String             @id @default(uuid()) @db.VarChar(36)
  noteNumber       String             @unique @map("note_number") @db.VarChar(50)
  supplierName     String             @map("supplier_name") @db.VarChar(255)
  receivedDate     DateTime           @map("received_date") @db.Date
  receivedByUserId String             @map("received_by_user_id") @db.VarChar(36)
  notes            String?            @db.Text
  status           DeliveryNoteStatus @default(pending)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  receivedBy User               @relation(fields: [receivedByUserId], references: [id])
  items      DeliveryNoteItem[]

  @@index([status])
  @@index([receivedDate])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             String           @id @default(uuid()) @db.VarChar(36)
  deliveryNoteId String           @map("delivery_note_id") @db.VarChar(36)
  itemType       DeliveryItemType @map("item_type")
  description    String           @db.VarChar(500)
  quantity       Int
  unitCost       Decimal          @map("unit_cost") @db.Decimal(12, 2)
  createdAt      DateTime         @default(now()) @map("created_at")

  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id])
  motorcycles  Motorcycle[]

  @@index([deliveryNoteId])
  @@map("delivery_note_items")
}

model Contract {
  id                     String         @id @default(uuid()) @db.VarChar(36)
  contractNumber         String         @unique @map("contract_number") @db.VarChar(50)
  customerId             String         @map("customer_id") @db.VarChar(36)
  totalPrincipal         Decimal        @map("total_principal") @db.Decimal(12, 2)
  totalInterest          Decimal        @map("total_interest") @db.Decimal(12, 2)
  totalAmount            Decimal        @map("total_amount") @db.Decimal(12, 2)
  numInstallments        Int            @map("num_installments")
  interestRate           Decimal        @map("interest_rate") @db.Decimal(5, 2)
  startDate              DateTime       @map("start_date") @db.Date
  financialInstitutionId String?        @map("financial_institution_id") @db.VarChar(36)
  status                 ContractStatus @default(active)
  notes                  String?        @db.Text
  createdByUserId        String         @map("created_by_user_id") @db.VarChar(36)
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  customer              Customer              @relation(fields: [customerId], references: [id])
  createdBy             User                  @relation("CreatedContracts", fields: [createdByUserId], references: [id])
  financialInstitution  FinancialInstitution? @relation(fields: [financialInstitutionId], references: [id])
  contractSales         ContractSale[]
  installments          Installment[]
  payments              Payment[]
  contractParties       ContractParty[]

  @@index([customerId])
  @@index([status])
  @@index([financialInstitutionId])
  @@map("contracts")
}

model FinancialInstitution {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @db.VarChar(255)
  code        String   @unique @db.VarChar(50)
  contactInfo String?  @map("contact_info") @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sales     Sale[]
  contracts Contract[]

  @@map("financial_institutions")
}

model ContractParty {
  id            String            @id @default(uuid()) @db.VarChar(36)
  contractId    String            @map("contract_id") @db.VarChar(36)
  role          ContractPartyRole
  partyName     String            @map("party_name") @db.VarChar(255)
  partyRefId    String?           @map("party_ref_id") @db.VarChar(36)
  partyRefType  String?           @map("party_ref_type") @db.VarChar(50)
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([role])
  @@map("contract_parties")
}

model ContractSale {
  id         String   @id @default(uuid()) @db.VarChar(36)
  contractId String   @map("contract_id") @db.VarChar(36)
  saleId     String   @map("sale_id") @db.VarChar(36)
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id])
  sale     Sale     @relation(fields: [saleId], references: [id])

  @@unique([contractId, saleId])
  @@index([contractId])
  @@index([saleId])
  @@map("contract_sales")
}
